ENV=

APP_PORT=
APP_ROUTE_PREFIX=/v1/cs-agent-bot

LOG_LEVEL=info

DB_ENABLED=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=

# PostgreSQL Connection Pool Settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_QUERY_TIMEOUT=30s
DB_STATS_LOGGING_ENABLED=false

REDIS_ENABLED=
REDIS_DB=
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=

# SERVICE DEPENDENCIES
# Add any service-specific dependencies here

# Event Dispatcher Settings (for webhook delivery to caller services)
DISPATCHER_ENABLED=true
DISPATCHER_POLL_INTERVAL=5s
DISPATCHER_HTTP_TIMEOUT=30s
DISPATCHER_BATCH_SIZE=100

# Webhook Settings
WEBHOOK_DEBUG_LOGGING=false

# OpenTelemetry Tracing
TRACER_EXPORTER=zipkin
TRACER_ZIPKIN_CREATE_SPAN_URL=http://zipkin:9411/api/v2/spans
TRACER_SERVICE_NAME=cs-agent-bot
TRACER_SERVICE_VERSION=v1.0.0

# Error Handling
ENABLE_STACK_TRACE=false
