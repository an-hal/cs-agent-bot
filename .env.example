ENV=development
APP_PORT=8080
APP_ROUTE_PREFIX=/v1/cs-agent-bot
LOG_LEVEL=info

DB_ENABLED=false
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=cs_agent_bot
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_QUERY_TIMEOUT=30s
DB_STATS_LOGGING_ENABLED=false

REDIS_ENABLED=true
REDIS_DB=0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

HALOAI_API_URL=
WA_API_TOKEN=
WA_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_AE_LEAD_ID=

GOOGLE_SA_KEY_FILE=./credentials/service_account.json
SPREADSHEET_ID=

APP_URL=
SCHEDULER_SA_EMAIL=

HANDOFF_WEBHOOK_SECRET=

PROMO_DEADLINE=
SURVEY_PLATFORM_URL=
CHECKIN_FORM_URL=
REFERRAL_BENEFIT=1 bulan gratis

TRACER_EXPORTER=zipkin
TRACER_ZIPKIN_CREATE_SPAN_URL=http://zipkin:9411/api/v2/spans
TRACER_SERVICE_NAME=cs-agent-bot
TRACER_SERVICE_VERSION=v1.0.0

GCP_PROJECT=

ENABLE_STACK_TRACE=false
